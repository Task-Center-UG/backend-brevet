APP_ENV=production
APP_PORT=8083
APP_HOST_PORT=8083
BODY_LIMIT_MB=20

# Domain that points to the Hostinger VPS public IP, for example api.example.com.
DOMAIN=api.example.com
FRONTEND_URL=https://example.com
ALLOWED_ORIGINS=https://example.com,https://www.example.com

DOCKER_IMAGE=zidanindratama/backend-brevet:latest

DB_HOST=db
DB_USER=postgres
DB_PASSWORD=change-this-strong-password
DB_NAME=brevetdb
DB_PORT=5432
DB_SSLMODE=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

ACCESS_TOKEN_SECRET=change-this-long-random-secret
REFRESH_TOKEN_SECRET=change-this-long-random-secret
VERIFICATION_TOKEN_SECRET=change-this-long-random-secret
ACCESS_TOKEN_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_HOURS=24
VERIFICATION_TOKEN_EXPIRY_MINUTES=15
TOKEN_BLACKLIST_TTL=86400
CLEANUP_INTERVAL_HOURS=1

UPLOAD_DIR=/root/public/uploads

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=change-this-smtp-password
